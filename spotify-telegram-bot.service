[Unit]
Description=Spotify Telegram Bot
After=network.target

[Service]
Type=simple
User=funlife
WorkingDirectory=/home/funlife/spotify-telegram-bot
EnvironmentFile=/home/funlife/spotify-telegram-bot/.env
ExecStart=/home/funlife/miniconda3/envs/spotify-downloader/bin/python /home/funlife/spotify-telegram-bot/bot.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
