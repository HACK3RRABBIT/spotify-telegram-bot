# Get your token from https://t.me/botfather
TELEGRAM_BOT_TOKEN=

# Simultaneous downloads (1 recommended for 1-core/1GB VPS)
MAX_CONCURRENT=1

# Audio format: m4a (fastest, no re-encoding) or mp3 (universal, slower)
AUDIO_FORMAT=m4a

# Proxy to bypass YouTube server IP blocks (set by install.sh automatically)
# YTDLP_PROXY=socks5://127.0.0.1:40000    # Cloudflare WARP
# SPOTDL_PROXY=http://127.0.0.1:8118       # privoxy HTTP bridge for spotdl
YTDLP_PROXY=
SPOTDL_PROXY=
